# ============================================================
# autoelectrico.uy — Variables de entorno
#
# Copiá este archivo a .env.local (nunca comitear .env.local)
# y completá los valores.
#
# En EasyPanel van en Project → Environment.
# ============================================================

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=https://autoelectrico.uy
CDN_DOMAIN=cdn.autoelectrico.uy

# --- Postgres (pgvector) ---
DATABASE_URL=postgresql://evuy:CAMBIAR@postgres:5432/evuy
POSTGRES_USER=evuy
POSTGRES_PASSWORD=          # openssl rand -base64 32
POSTGRES_DB=evuy

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=              # openssl rand -hex 16
S3_SECRET_KEY=              # openssl rand -base64 32

# --- Auth.js ---
AUTH_SECRET=                # openssl rand -base64 32
AUTH_URL=https://autoelectrico.uy

# --- APIs ---
ANTHROPIC_API_KEY=          # Claude: el chatbot
OPENAI_API_KEY=             # Embeddings: text-embedding-3-small

# --- Mail (Resend) ---
RESEND_API_KEY=
MAIL_FROM=autoelectrico.uy <hola@autoelectrico.uy>
MAIL_REPLY_TO=matideleon@gmail.com

# --- Backup ---
BACKUP_REMOTE=remote/autoelectrico-backups
